{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "CMake: build debug",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--config Debug",
                "--target all",
                "-j 4",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
        },
        {
            "type": "shell",
            "label": "CMake: clean",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build",
                "--target",
                "clean"
            ],
            "group": {
                "kind": "build"
            },
            "problemMatcher": []
        }
    ]
}